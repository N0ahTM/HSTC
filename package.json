{
  "name": "hstc-amplify-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:function": "cross-env FUNCTION_PORT=3000 tsx ./scripts/local-function-server.ts",
    "test:function": "tsx ./scripts/test-discord-function.ts",
    "dev:full": "concurrently \"npm:dev:function\" \"npm:dev\"",
    "build": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "sandbox": "npx -y -p @aws-amplify/backend-cli@latest ampx sandbox",
    "sandbox:remove": "npx -y -p @aws-amplify/backend-cli@latest ampx sandbox --remove",
    "ampx:version": "npx -y -p @aws-amplify/backend-cli@latest ampx -v",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "animejs": "^3.2.2",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.16.1",
    "@aws-amplify/backend-cli": "^1.8.0",
    "@aws-amplify/cli": "^14.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/animejs": "^3.1.13",
    "@types/node": "^20.19.20",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-testing-library": "^7.13.1",
    "jsdom": "^24.1.3",
    "patch-package": "^8.0.1",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^5.4.20",
    "vitest": "^1.6.1"
  }
}
